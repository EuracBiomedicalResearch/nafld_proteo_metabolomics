.randomize_grouping <- function(x,
max_nstd,
min_nstd,
min_diff = 2) {
n <- nrow(x)
standard_groups <- vector("list")
i <- 0
while(length(standard_groups) == 0 || any(lengths(standard_groups) < min_nstd)) {
i <- i +1
x <- x[sample(n), ]
standard_groups <- .group_standards_iteration(x,
max_nstd = max_nstd,
min_diff = min_diff)
if(i > n*n)
stop("all combination were tested, no possibility to fit your input requirement")
}
standard_groups
}
x1<- x[sample(nrow(x), 8),]
standard_groups <- .group_standards_iteration(x1, max_nstd = 4, min_diff = 2)
View(standard_groups)
test_result_r <- .randomize_grouping(x1, max_nstd = 4, min_nstd = 3, min_diff = 2)
